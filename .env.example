# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=netsentinel
DB_PASSWORD=netsentinel_secret
DB_NAME=netsentinel
DATABASE_URL=postgresql+asyncpg://netsentinel:netsentinel_secret@localhost:5432/netsentinel

# Redis
REDIS_URL=redis://localhost:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Scanning
SCAN_NETWORK=192.168.1.0/24
DISCOVERY_INTERVAL_MINUTES=5
PORT_SCAN_INTERVAL_MINUTES=60
TRAFFIC_CAPTURE_ENABLED=true

# GeoIP (MaxMind)
GEOIP_DB_PATH=./data/GeoLite2-City.mmdb
